# Core service auth and storage
TRADER_KOO_API_KEY=replace-with-a-shared-admin-secret
TRADER_KOO_DB_PATH=/data/trader_koo.db
TRADER_KOO_LOG_DIR=/data/logs
TRADER_KOO_REPORT_DIR=/data/reports

# Public app URL and API metadata
TRADER_KOO_ALLOWED_ORIGIN=https://trader.kooexperience.com
TRADER_KOO_BASE_URL=https://trader.kooexperience.com
TRADER_KOO_APP_URL=https://trader.kooexperience.com
TRADER_KOO_REPO_URL=https://github.com/your-org/trader-koo

# Ingest and pipeline safety
TRADER_KOO_LOG_LEVEL=INFO
TRADER_KOO_INGEST_MAX_SECS_PER_TICKER=120
TRADER_KOO_PRICE_TIMEOUT_SEC=25
TRADER_KOO_PRICE_RETRY_ATTEMPTS=3
TRADER_KOO_YOLO_MAX_SECS_PER_TICKER=180
TRADER_KOO_PIPELINE_STALE_SEC=1200

# Optional external data
TRADER_KOO_ALPHA_VANTAGE_KEY=

# Optional LLM text generation (rule-grounded)
TRADER_KOO_LLM_ENABLED=0
TRADER_KOO_LLM_PROVIDER=azure_openai
TRADER_KOO_LLM_MAX_SETUPS=8
TRADER_KOO_LLM_TIMEOUT_SEC=8
TRADER_KOO_LLM_TEMPERATURE=0.2
TRADER_KOO_LLM_MAX_TOKENS=220
TRADER_KOO_LLM_DISABLE_SEC_ON_FAIL=300
TRADER_KOO_LLM_DEGRADED_FAILS=3
TRADER_KOO_LLM_FAILURE_EVENT_COOLDOWN_SEC=300
TRADER_KOO_LLM_HEALTH_MAX_EVENTS=5000
TRADER_KOO_LLM_FAIL_ALERT_ENABLED=1
# Canonical recipient override key for degraded-LLM operator alerts.
# Legacy alias TRADER_KOO_LLM_ALERT_TO is still accepted for backward compatibility.
TRADER_KOO_LLM_FAIL_ALERT_TO=
TRADER_KOO_LLM_FAIL_ALERT_COOLDOWN_MIN=180

# Optional multi-angle debate payload (rule-first, TradingAgents-style architecture)
TRADER_KOO_DEBATE_ENABLED=1
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=
AZURE_OPENAI_EMBEDDING_ENDPOINT=
AZURE_OPENAI_EMBEDDING_API_KEY=
AZURE_OPENAI_EMBEDDING_API_VERSION=2024-02-01
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# Optional first-party usage analytics for control-center rollups
TRADER_KOO_ANALYTICS_ENABLED=1
TRADER_KOO_ANALYTICS_MAX_SESSION_AGE_DAYS=180

# Optional email delivery
TRADER_KOO_SMTP_HOST=
TRADER_KOO_SMTP_PORT=587
TRADER_KOO_SMTP_SECURITY=starttls
TRADER_KOO_SMTP_USER=
TRADER_KOO_SMTP_PASS=
TRADER_KOO_SMTP_FROM=
TRADER_KOO_REPORT_EMAIL_TO=
TRADER_KOO_SMTP_TIMEOUT_SEC=30
TRADER_KOO_EMAIL_TRANSPORT=auto
TRADER_KOO_RESEND_API_KEY=
TRADER_KOO_RESEND_FROM=
TRADER_KOO_RESEND_TIMEOUT_SEC=30
TRADER_KOO_EMAIL_SUBSCRIBE_ENABLED=1
